# ============================================================================
# Enterprise Test Artifact Generation Platform — Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================================

# ── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_USER=qa_user
POSTGRES_PASSWORD=secure_password_here
POSTGRES_DB=qa_rag
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ── Qdrant Vector Database ─────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
# QDRANT_API_KEY=your_qdrant_api_key     # Optional: only if Qdrant auth is enabled

# ── LLM Providers (Universal Configuration) ─────────────────────────────────
# Choose your provider: mistral, openai, anthropic, ollama
LLM_PROVIDER=mistral
LLM_MODEL_NAME=mistral-large-latest
LLM_API_KEY=your_llm_api_key_here

# Optional: Specific Embedding Model (defaults to LLM settings if missing)
EMBEDDING_PROVIDER=mistral
EMBEDDING_MODEL_NAME=mistral-embed
# EMBEDDING_API_KEY=your_embedding_api_key_here

# ── Ollama (local LLM — optional) ──────────────────────────────────────────
OLLAMA_PORT=11434

# ── Extraction Service ─────────────────────────────────────────────────────
# URL of document extraction API (Docling/Unstructured)
EXTRACTION_SERVICE_URL=http://localhost:8000
# UNSTRUCTURED_API_KEY=your_key_here

# ── JIRA Integration (optional) ────────────────────────────────────────────
JIRA_URL=https://your-domain.atlassian.net
JIRA_USERNAME=your_email@example.com
JIRA_API_TOKEN=your_jira_api_token_here

# ── Local Paths (Optional Overrides) ────────────────────────────────────────
# INPUT_ROOT=d:\Projects\VDRC\Automation\test-case-gen-rag\langchain_test-gen-docs\input_documents

# ============================================================================
# OPTIONAL INTEGRATIONS (Not required for standalone pipeline)
# ============================================================================

# ── MinIO Object Storage ───────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=source-documents

# ── n8n Workflow Engine ────────────────────────────────────────────────────
N8N_PORT=5678
N8N_USER=admin
N8N_PASSWORD=admin_password
WEBHOOK_URL=http://localhost:5678/
TIMEZONE=UTC+05:30

# ── Redis (optional — for n8n caching) ──────────────────────────────────────
REDIS_PORT=6379

# ── RAGAS Evaluation Tuning ────────────────────────────────────────────────
# Delay (in seconds) between each RAGAS evaluation call to avoid 429 rate limits.
# Increase if you still hit rate limits; decrease for faster evaluation.
EVAL_DELAY_SECONDS=5
